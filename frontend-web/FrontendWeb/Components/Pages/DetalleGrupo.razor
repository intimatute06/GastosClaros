@page "/grupos/{GrupoId:int}"
@rendermode InteractiveServer
@using FrontendWeb.Models
@using FrontendWeb.Services.Interfaces
@inject IBackendCoreApi Api

<PageTitle>GastosClaros - Detalle</PageTitle>

@if (grupo == null)
{
    <div class="loading-state">
        <div class="spinner-border spinner-inline" role="status" aria-hidden="true"></div>
        <span>Cargando grupo...</span>
    </div>
}
else
{
    <a href="/" class="back-link">← Volver a mis grupos</a>
    <h1>@grupo.Nombre</h1>
    <p class="page-subtitle">Miembros, gastos y saldos del grupo.</p>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card-surface h-100">
                <div class="section-label">Miembros</div>
                <EditForm Model="@nuevoMiembro" OnValidSubmit="CrearMiembro">
                    <InputText class="form-control mb-2" @bind-Value="nuevoMiembro.Nombre" placeholder="Nombre" />
                    <InputText class="form-control mb-2" @bind-Value="nuevoMiembro.Email" placeholder="Email" />
                    <button type="submit" class="btn btn-primary btn-sm w-100">Agregar miembro</button>
                </EditForm>

                <div class="miembros-list mt-3">
                    @foreach (var miembro in miembros)
                    {
                        <div class="miembro-item">
                            <span class="miembro-avatar">@ObtenerIniciales(miembro.Nombre)</span>
                            <div class="miembro-info">
                                <span class="miembro-nombre">@miembro.Nombre</span>
                                <span class="miembro-email">@miembro.Email</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card-surface mb-4">
                <div class="section-label">Registrar gasto</div>
                <EditForm Model="@nuevoGasto" OnValidSubmit="CrearGasto">
                    <div class="row g-2 align-items-center">
                        <div class="col-12 col-md">
                            <InputText class="form-control" @bind-Value="nuevoGasto.Descripcion" placeholder="Descripcion" />
                        </div>
                        <div class="col-6 col-md-3">
                            <InputNumber class="form-control" @bind-Value="nuevoGasto.Monto" placeholder="Monto" />
                        </div>
                        <div class="col-6 col-md-3">
                            <InputSelect class="form-select" @bind-Value="nuevoGasto.PagadoPorId">
                                <option value="0">Quien pago...</option>
                                @foreach (var miembro in miembros)
                                {
                                    <option value="@miembro.Id">@miembro.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-auto">
                            <button type="submit" class="btn btn-primary w-100">Registrar</button>
                        </div>
                    </div>
                </EditForm>

                @if (mensajeError != null)
                {
                    <div class="alert alert-danger mt-3 mb-0">@mensajeError</div>
                }
            </div>

            <div class="card-surface mb-4">
                <div class="section-label">Gastos</div>

                @if (gastos.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">🧾</span>
                        <p class="mb-0">Todavia no hay gastos registrados.</p>
                    </div>
                }
                else
                {
                    <div class="gastos-list">
                        @foreach (var gasto in gastos)
                        {
                            var badge = ObtenerBadgeCategoria(gasto.Categoria);
                            <div class="gasto-item">
                                <div class="gasto-main">
                                    <span class="gasto-descripcion">@gasto.Descripcion</span>
                                    <span class="gasto-pagador">Pagado por @gasto.PagadoPorNombre</span>
                                </div>
                                <div class="gasto-side">
                                    <span class="gasto-monto">$@gasto.Monto.ToString("0.00")</span>
                                    <span class="badge-categoria @badge.CssClass">@badge.Emoji @(string.IsNullOrWhiteSpace(gasto.Categoria) ? "Sin clasificar" : gasto.Categoria)</span>
                                    <select class="form-select form-select-sm categoria-select" value="@(gasto.Categoria ?? "")" @onchange="(e) => CambiarCategoria(gasto, e.Value?.ToString())">
                                        <option value="">Sin clasificar</option>
                                        <option value="Comida">Comida</option>
                                        <option value="Transporte">Transporte</option>
                                        <option value="Alojamiento">Alojamiento</option>
                                        <option value="Entretenimiento">Entretenimiento</option>
                                        <option value="Otros">Otros</option>
                                    </select>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card-surface">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="section-label mb-0">Saldos</div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CargarSaldos">Actualizar saldos</button>
                </div>

                @if (mensajePago != null)
                {
                    <div class="alert @(pagoExitoso ? "alert-success" : "alert-warning")">@mensajePago</div>
                }

                @if (saldos.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">✅</span>
                        <p class="mb-0">No hay saldos pendientes.</p>
                    </div>
                }
                else
                {
                    <div class="saldos-list">
                        @foreach (var saldo in saldos)
                        {
                            <div class="balance-row card-surface saldo-item">
                                <div class="balance-parties">
                                    <span class="balance-chip balance-chip-deudor">@saldo.DeudorNombre</span>
                                    <span class="balance-arrow">
                                        <span>$@saldo.Monto.ToString("0.00")</span>
                                        <span>→</span>
                                    </span>
                                    <span class="balance-chip balance-chip-acreedor">@saldo.AcreedorNombre</span>
                                </div>
                                <button class="btn btn-sm btn-success" disabled="@procesandoPago" @onclick="() => SaldarDeuda(saldo)">
                                    @if (procesandoPago)
                                    {
                                        <span class="spinner-border spinner-border-sm spinner-inline me-1" role="status" aria-hidden="true"></span>
                                        <span>Procesando...</span>
                                    }
                                    else
                                    {
                                        <span>Saldar</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int GrupoId { get; set; }

    private GrupoModel? grupo;
    private List<MiembroModel> miembros = new();
    private List<GastoModel> gastos = new();
    private List<SaldoModel> saldos = new();
    private CrearMiembroModel nuevoMiembro = new();
    private CrearGastoModel nuevoGasto = new();
    private string? mensajeError;
    private string? mensajePago;
    private bool pagoExitoso;
    private bool procesandoPago;

    private static (string Emoji, string CssClass) ObtenerBadgeCategoria(string? categoria) => categoria switch
    {
        "Comida" => ("🍔", "badge-comida"),
        "Transporte" => ("🚗", "badge-transporte"),
        "Alojamiento" => ("🏠", "badge-alojamiento"),
        "Entretenimiento" => ("🎬", "badge-entretenimiento"),
        "Otros" => ("📦", "badge-otros"),
        _ => ("❔", "badge-sinclasificar"),
    };

    private static string ObtenerIniciales(string nombre)
    {
        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return partes.Length switch
        {
            0 => "?",
            1 => partes[0][..Math.Min(2, partes[0].Length)].ToUpperInvariant(),
            _ => $"{partes[0][0]}{partes[^1][0]}".ToUpperInvariant(),
        };
    }

    protected override async Task OnInitializedAsync()
    {
        grupo = await Api.GetGrupoAsync(GrupoId);
        nuevoGasto.GrupoId = GrupoId;
        await CargarMiembros();
        await CargarGastos();
        await CargarSaldos();
    }

    private async Task CargarMiembros()
    {
        miembros = await Api.GetMiembrosPorGrupoAsync(GrupoId);
    }

    private async Task CargarGastos()
    {
        gastos = await Api.GetGastosPorGrupoAsync(GrupoId);
    }

    private async Task CargarSaldos()
    {
        saldos = await Api.GetSaldosPorGrupoAsync(GrupoId);
    }

    private async Task CambiarCategoria(GastoModel gasto, string? nuevaCategoria)
    {
        if (string.IsNullOrWhiteSpace(nuevaCategoria)) return;

        var exito = await Api.ActualizarCategoriaGastoAsync(gasto.Id, nuevaCategoria);
        if (exito)
        {
            await CargarGastos();
        }
    }
    private async Task CrearMiembro()
    {
        nuevoMiembro.GrupoId = GrupoId;
        var creado = await Api.CrearMiembroAsync(nuevoMiembro);
        if (creado != null)
        {
            nuevoMiembro = new CrearMiembroModel();
            await CargarMiembros();
        }
    }

    private async Task CrearGasto()
    {
        mensajeError = null;

        if (nuevoGasto.PagadoPorId == 0)
        {
            mensajeError = "Selecciona quien pago el gasto.";
            return;
        }

        var creado = await Api.CrearGastoAsync(nuevoGasto);
        if (creado == null)
        {
            mensajeError = "No se pudo registrar el gasto.";
            return;
        }

        nuevoGasto = new CrearGastoModel { GrupoId = GrupoId };
        await CargarGastos();
        await CargarSaldos();
    }

    private async Task SaldarDeuda(SaldoModel saldo)
    {
        procesandoPago = true;
        mensajePago = null;
        StateHasChanged();

        var deudaCreada = await Api.CrearDeudaAsync(new CrearDeudaModel
        {
            DeudorId = saldo.DeudorId,
            AcreedorId = saldo.AcreedorId,
            Monto = saldo.Monto
        });

        if (deudaCreada == null)
        {
            mensajePago = "No se pudo crear la deuda para saldar.";
            pagoExitoso = false;
            procesandoPago = false;
            return;
        }

        var resultado = await Api.SaldarDeudaAsync(deudaCreada.Id);

        if (resultado != null && resultado.Estado == "Saldada")
        {
            pagoExitoso = true;
            mensajePago = $"Pago procesado: {saldo.DeudorNombre} salda " + saldo.Monto.ToString("0.00") + $" a {saldo.AcreedorNombre}. Referencia: {resultado.ReferenciaTransaccion}";
        }
        else
        {
            pagoExitoso = false;
            mensajePago = "El pago simulado fallo. Intenta nuevamente.";
        }

        procesandoPago = false;
        await CargarGastos();
        await CargarSaldos();
    }
}
