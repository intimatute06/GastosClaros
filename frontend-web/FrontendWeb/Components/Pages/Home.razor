@page "/"
@rendermode InteractiveServer
@using FrontendWeb.Models
@using FrontendWeb.Services.Interfaces
@inject IBackendCoreApi Api
@inject NavigationManager NavManager

<PageTitle>GastosClaros - Grupos</PageTitle>

<h1>Mis Grupos</h1>
<p class="page-subtitle">Selecciona un grupo para ver el detalle o crea uno nuevo.</p>

<div class="card-surface mb-4">
    <div class="section-label">Nuevo grupo</div>
    <EditForm Model="@nuevoGrupo" OnValidSubmit="CrearGrupo">
        <div class="d-flex gap-2 flex-wrap">
            <InputText class="form-control" style="flex: 1; min-width: 220px;" @bind-Value="nuevoGrupo.Nombre" placeholder="Nombre del grupo (ej. Viaje a Banos)" />
            <button type="submit" class="btn btn-primary">Crear grupo</button>
        </div>
    </EditForm>

    @if (mensajeError != null)
    {
        <div class="alert alert-danger mt-3 mb-0">@mensajeError</div>
    }
</div>

@if (grupos == null)
{
    <div class="loading-state">
        <div class="spinner-border spinner-inline" role="status" aria-hidden="true"></div>
        <span>Cargando grupos...</span>
    </div>
}
else if (grupos.Count == 0)
{
    <div class="empty-state card-surface">
        <span class="empty-icon">📋</span>
        <p class="mb-0">Todavia no tienes grupos. Crea el primero arriba.</p>
    </div>
}
else
{
    <div class="grupos-grid">
        @foreach (var grupo in grupos)
        {
            <div class="card-surface grupo-card">
                <h3 class="mb-2">@grupo.Nombre</h3>
                <div class="grupo-meta">
                    <span>👥 @grupo.CantidadMiembros miembro@(grupo.CantidadMiembros == 1 ? "" : "s")</span>
                    <span>📅 @grupo.FechaCreacion.ToString("dd/MM/yyyy")</span>
                </div>
                <button class="btn btn-outline-primary btn-sm mt-3" @onclick="() => VerDetalle(grupo.Id)">
                    Ver detalle
                </button>
            </div>
        }
    </div>
}

@code {
    private List<GrupoModel>? grupos;
    private CrearGrupoModel nuevoGrupo = new();
    private string? mensajeError;

    protected override async Task OnInitializedAsync()
    {
        await CargarGrupos();
    }

    private async Task CargarGrupos()
    {
        grupos = await Api.GetGruposAsync();
    }

    private async Task CrearGrupo()
    {
        mensajeError = null;

        if (string.IsNullOrWhiteSpace(nuevoGrupo.Nombre))
        {
            mensajeError = "El nombre del grupo no puede estar vacio.";
            return;
        }

        var creado = await Api.CrearGrupoAsync(nuevoGrupo);
        if (creado == null)
        {
            mensajeError = "No se pudo crear el grupo. Verifica que el Backend Core este corriendo.";
            return;
        }

        nuevoGrupo = new CrearGrupoModel();
        await CargarGrupos();
    }

    private void VerDetalle(int grupoId)
    {
        NavManager.NavigateTo($"/grupos/{grupoId}");
    }
}
